# 📦 Node dependencies (NEVER commit this)
node_modules/

# 🔐 Env files (you leak secrets otherwise)
.env
.env.*

# 🏗 Build outputs
dist/
build/
.out/

# ⚡ Vite cache
.vite/

# 🦀 Tauri build artifacts
src-tauri/target/
src-tauri/.cargo/

# 🧠 Logs (useless noise)
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# 🧹 OS garbage
.DS_Store
Thumbs.db

# 🧰 IDE/editor junk
.vscode/
.idea/
*.swp
*.swo

# 🐍 Python cache (you literally have a .py file)
__pycache__/
*.pyc

# 🔒 Lockfiles (IMPORTANT DECISION)
# KEEP package-lock.json if this is an app
# REMOVE this line if you're building a library
# package-lock.json

# 🧪 Temporary files
*.tmp
*.temp
